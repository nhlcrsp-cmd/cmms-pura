// ======================================================
// TIPO ITEM INVENTARIO
// ======================================================

model TipoItemInventario {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                      BigInt   @id @default(autoincrement())

  uuid                    String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo                  String   @unique

  nombre                  String

  descripcion             String?

  // ----------------------------------------------------
  // Comportamiento
  // ----------------------------------------------------

  controlaStock           Boolean  @default(true)

  admiteStockNegativo     Boolean  @default(false)

  requiereSerie           Boolean  @default(false)

  requiereLote            Boolean  @default(false)

  esConsumible            Boolean  @default(true)

  esHerramienta           Boolean  @default(false)

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre             String?

  colorHex                String?

  ordenVisual             Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo                  Boolean  @default(true)

  eliminadoEn             DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn                DateTime @default(now())

  actualizadoEn           DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  itemsInventario         ItemInventario[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@index([controlaStock])

  @@map("tipos_item_inventario")

}
// ======================================================
// UNIDAD DE MEDIDA INVENTARIO
// ======================================================

model UnidadMedidaInventario {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  abreviatura         String

  descripcion         String?

  // ----------------------------------------------------
  // Configuración
  // ----------------------------------------------------

  permiteDecimales    Boolean  @default(true)

  ordenVisual         Int?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  itemsInventario     ItemInventario[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  @@unique([abreviatura])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@map("unidades_medida_inventario")

}
