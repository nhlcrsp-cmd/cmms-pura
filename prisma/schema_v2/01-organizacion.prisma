// ====================================================== // DOMINIO
01 - ORGANIZACIÓN // Release 2.1 (BORRADOR ARQUITECTÓNICO) //
======================================================

model Empresa {

id BigInt @id @default(autoincrement()) uuid String @unique
@default(uuid())

codigo String @unique razonSocial String nombreComercial String?
identificacionFiscal String? descripcion String?

iconoNombre String? colorHex String?

activo Boolean @default(true) eliminadoEn DateTime?

creadoEn DateTime @default(now()) actualizadoEn DateTime @updatedAt

unidadesOrganizacionales UnidadOrganizacional[]

@@unique([razonSocial]) @@index([codigo]) @@index([razonSocial])
@@map(“empresas”) }

model TipoUnidadOrganizacional {

id BigInt @id @default(autoincrement()) uuid String @unique
@default(uuid())

codigo String @unique nombre String descripcion String?

iconoNombre String? colorHex String? ordenVisual Int?

permitePadre Boolean @default(true) permiteHijos Boolean @default(true)
admiteActivos Boolean @default(true) admitePersonas Boolean
@default(true) admiteInventario Boolean @default(true)
admiteOrdenesTrabajo Boolean @default(true)

activo Boolean @default(true) eliminadoEn DateTime?

creadoEn DateTime @default(now()) actualizadoEn DateTime @updatedAt

unidadesOrganizacionales UnidadOrganizacional[]

@@unique([nombre]) @@map(“tipos_unidad_organizacional”) }

model UnidadOrganizacional {

id BigInt @id @default(autoincrement()) uuid String @unique
@default(uuid())

empresaId BigInt tipoUnidadOrganizacionalId BigInt padreId BigInt?

codigo String nombre String descripcion String?

iconoNombre String? colorHex String? ordenVisual Int?

activo Boolean @default(true) eliminadoEn DateTime?

creadoEn DateTime @default(now()) actualizadoEn DateTime @updatedAt

empresa Empresa @relation(fields: [empresaId], references: [id],
onDelete: Restrict) tipo TipoUnidadOrganizacional @relation(fields:
[tipoUnidadOrganizacionalId], references: [id], onDelete: Restrict)

padre UnidadOrganizacional? @relation(“UnidadPadre”, fields: [padreId],
references: [id], onDelete: Restrict) hijos UnidadOrganizacional[]
@relation(“UnidadPadre”)

closureComoAncestro UnidadOrganizacionalClosure[]
@relation(“ClosureAncestro”) closureComoDescendiente
UnidadOrganizacionalClosure[] @relation(“ClosureDescendiente”)

@@unique([empresaId, codigo]) @@unique([empresaId, padreId, nombre])

@@index([empresaId]) @@index([tipoUnidadOrganizacionalId])
@@index([padreId])

@@map(“unidades_organizacionales”) }

model UnidadOrganizacionalClosure {

ancestroId BigInt descendienteId BigInt profundidad Int

ancestro UnidadOrganizacional @relation(“ClosureAncestro”, fields:
[ancestroId], references: [id], onDelete: Cascade) descendiente
UnidadOrganizacional @relation(“ClosureDescendiente”, fields:
[descendienteId], references: [id], onDelete: Cascade)

@@id([ancestroId, descendienteId])

@@index([ancestroId]) @@index([descendienteId]) @@index([ancestroId,
profundidad]) @@index([descendienteId, profundidad])

@@map(“unidades_organizacionales_closure”) }
