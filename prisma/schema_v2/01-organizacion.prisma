// ====================================================== 
// DOMINIO 01 - ORGANIZACIÓN 
// Release 2.1 (BORRADOR ARQUITECTÓNICO) 
//======================================================

// ======================================================
// EMPRESA
// ======================================================

model Empresa {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  razonSocial         String

  nombreComercial     String?

  identificacionFiscal String?

  descripcion         String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  unidadesOrganizacionales UnidadOrganizacional[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([razonSocial])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@index([razonSocial])

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@map("empresas")

}
// ======================================================
// TIPO UNIDAD ORGANIZACIONAL
// ======================================================

model TipoUnidadOrganizacional {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  descripcion         String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  ordenVisual         Int?

  // ----------------------------------------------------
  // Comportamiento
  // ----------------------------------------------------

  permitePadre        Boolean  @default(true)

  permiteHijos        Boolean  @default(true)

  admiteActivos       Boolean  @default(true)

  admitePersonas      Boolean  @default(true)

  admiteInventario    Boolean  @default(true)

  admiteOrdenesTrabajo Boolean @default(true)

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  unidadesOrganizacionales UnidadOrganizacional[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@index([nombre])

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@map("tipos_unidad_organizacional")

}
// ======================================================
// UNIDAD ORGANIZACIONAL
// ======================================================

model UnidadOrganizacional {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                          BigInt   @id @default(autoincrement())

  uuid                        String   @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  empresaId                   BigInt

  tipoUnidadOrganizacionalId  BigInt

  padreId                     BigInt?

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo                      String

  nombre                      String

  descripcion                 String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre                 String?

  colorHex                    String?

  ordenVisual                 Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo                      Boolean  @default(true)

  eliminadoEn                 DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn                    DateTime @default(now())

  actualizadoEn               DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  empresa Empresa
    @relation(
      fields: [empresaId],
      references: [id],
      onDelete: Restrict
    )

  tipo TipoUnidadOrganizacional
    @relation(
      fields: [tipoUnidadOrganizacionalId],
      references: [id],
      onDelete: Restrict
    )

  padre UnidadOrganizacional?
    @relation(
      "UnidadPadre",
      fields: [padreId],
      references: [id],
      onDelete: Restrict
    )

  hijos UnidadOrganizacional[]
    @relation("UnidadPadre")

  closureComoAncestro UnidadOrganizacionalClosure[]
    @relation("ClosureAncestro")

  closureComoDescendiente UnidadOrganizacionalClosure[]
    @relation("ClosureDescendiente")

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([empresaId, codigo])

  @@unique([empresaId, padreId, nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([empresaId])

  @@index([tipoUnidadOrganizacionalId])

  @@index([padreId])

  @@index([nombre])

  @@index ([empresaId, activo])

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@map("unidades_organizacionales")

}
// ======================================================
// UNIDAD ORGANIZACIONAL CLOSURE
// ======================================================

model UnidadOrganizacionalClosure {

  // ----------------------------------------------------
  // Clave primaria compuesta
  // ----------------------------------------------------

  ancestroId                  BigInt

  descendienteId              BigInt

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  profundidad                 Int

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  ancestro UnidadOrganizacional
    @relation(
      "ClosureAncestro",
      fields: [ancestroId],
      references: [id],
      onDelete: Cascade
    )

  descendiente UnidadOrganizacional
    @relation(
      "ClosureDescendiente",
      fields: [descendienteId],
      references: [id],
      onDelete: Cascade
    )

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@id([ancestroId, descendienteId])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([ancestroId])

  @@index([descendienteId])

  @@index([ancestroId, profundidad])

  @@index([descendienteId, profundidad])

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@map("unidades_organizacionales_closure")

}
