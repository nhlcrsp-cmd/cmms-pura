// ======================================================
// MARCA
// ======================================================

model Marca {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  descripcion         String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  ordenVisual         Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  modelos             Modelo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@index([nombre])

  @@map("marca")

}
// ======================================================
// MODELO
// ======================================================

model Modelo {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  marcaId             BigInt

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String

  nombre              String

  descripcion         String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  ordenVisual         Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  marca Marca @relation(
    fields: [marcaId],
    references: [id],
    onDelete: Restrict
  )

  // La relación con Activo se agregará en 05-activos.prisma
  // activos Activo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([marcaId, codigo])

  @@unique([marcaId, nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([marcaId])

  @@index([codigo])

  @@index([nombre])

  @@map("modelo")

}