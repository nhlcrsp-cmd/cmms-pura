// ======================================================
// ESTADO GENERAL
// ======================================================

model EstadoGeneral {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  descripcion         String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  ordenVisual         Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@index([nombre])

  @@index([ordenVisual])

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@map("estados_generales")

}

