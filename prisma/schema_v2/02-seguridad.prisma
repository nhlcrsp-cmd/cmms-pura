// ======================================================
// BLOQUE B4
// RECURSO DEL SISTEMA
// ======================================================

model RecursoSistema {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  dominioSistemaId Int

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo         String

  nombre         String

  descripcion    String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  icono          String?

  color          String?

  orden          Int       @default(0)

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo         Boolean   @default(true)

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn       DateTime  @default(now())

  actualizadoEn  DateTime  @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  dominioSistema DominioSistema @relation(
    fields: [dominioSistemaId],
    references: [id]
  )

  permisos       Permiso[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([dominioSistemaId, codigo])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([dominioSistemaId])

  @@index([nombre])

  @@index([activo])

}
