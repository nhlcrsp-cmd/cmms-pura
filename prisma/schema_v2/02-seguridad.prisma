// ======================================================
// BLOQUE B1
// USUARIO
// ======================================================

model Usuario {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())

  // ----------------------------------------------------
  // Organización
  // ----------------------------------------------------

  departamentoId Int

  // ----------------------------------------------------
  // Credenciales
  // ----------------------------------------------------

  usuario        String    @unique
  email          String?   @unique

  passwordHash   String

  // ----------------------------------------------------
  // Información personal
  // ----------------------------------------------------

  nombre         String
  apellido       String

  telefono       String?

  legajo         String?

  observaciones  String?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo         Boolean   @default(true)

  ultimoLoginEn  DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn       DateTime  @default(now())
  actualizadoEn  DateTime  @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  departamento   Departamento @relation(fields: [departamentoId], references: [id])

  roles          UsuarioRol[]

  rolesAsignados UsuarioRol[] @relation("UsuarioRolAsignadoPor")

  permisosAsignados RolPermiso[] @relation("RolPermisoAsignadoPor")

  sesiones       Sesion[]

  horasTrabajo   HoraTrabajo[]

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([departamentoId])

  @@index([apellido, nombre])

  @@index([activo])
}
// ======================================================
// BLOQUE B2
// ROL
// ======================================================

model Rol {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo         String    @unique

  nombre         String

  descripcion    String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  color          String?

  icono          String?

  orden          Int       @default(0)

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo         Boolean   @default(true)

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn       DateTime  @default(now())

  actualizadoEn  DateTime  @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  usuarios       UsuarioRol[]

  permisos       RolPermiso[]

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([nombre])

  @@index([activo])

}
// ======================================================
// BLOQUE B3
// DOMINIO DEL SISTEMA
// ======================================================

model DominioSistema {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo         String    @unique

  nombre         String

  descripcion    String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  icono          String?

  orden          Int       @default(0)

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo         Boolean   @default(true)

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn       DateTime  @default(now())

  actualizadoEn  DateTime  @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  recursos       RecursoSistema[]

  permisos       Permiso[]

  // ----------------------------------------------------
  // Índices
