// ======================================================
// 05-activos.prisma
// ======================================================

model activos{

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                      BigInt   @id @default(autoincrement())

  uuid                    String   @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  unidadOrganizacionalId  BigInt

  marcaId                 BigInt?

  modeloId                BigInt?

  activoPadreId           BigInt?

  plantillaTecnicaId BigInt


  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo                  String

  nombre                  String

  descripcion             String?

  numeroSerie             String?

  identificadorExterno String?

  // ----------------------------------------------------
  // Ciclo de vida
  // ----------------------------------------------------

  fechaPuestaServicio     DateTime?

  fechaBaja               DateTime?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo                  Boolean  @default(true)

  eliminadoEn             DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn                DateTime @default(now())

  actualizadoEn           DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  unidadOrganizacional UnidadOrganizacional @relation(
    fields: [unidadOrganizacionalId],
    references: [id],
    onDelete: Restrict
  )

  marca Marca? @relation(
    fields: [marcaId],
    references: [id],
    onDelete: Restrict
  )

  modelo Modelo? @relation(
    fields: [modeloId],
    references: [id],
    onDelete: Restrict
  )

  padre Activo? @relation(
    "ActivoPadre",
    fields: [activoPadreId],
    references: [id],
    onDelete: Restrict
  )

  plantillaTecnica PlantillaTecnica
  @relation(
    fields: [plantillaTecnicaId],
    references: [id],
    onDelete: Restrict
  )

  hijos activos] @relation("ActivoPadre")

  closureComoAncestro ActivoClosure[]
    @relation("ClosureAncestro")

  closureComoDescendiente ActivoClosure[]
    @relation("ClosureDescendiente")

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([unidadOrganizacionalId, codigo])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([unidadOrganizacionalId])
  @@index([marcaId])
  @@index([modeloId])
  @@index([activoPadreId])
  @@index([plantillaTecnicaId])
  @@index([numeroSerie])

  @@map("activos)



}
// ======================================================
// ACTIVOsCLOSURE
// ======================================================

model Activos_closure{

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  ancestroId        BigInt

  descendienteId    BigInt

  profundidad       Int

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  ancestro activos @Relation(
    "ClosureAncestro",
    fields: [ancestroId],
    references: [id],
    onDelete: Cascade
  )

  descendiente activos @relation(
    "ClosureDescendiente",
    fields: [descendienteId],
    references: [id],
    onDelete: Cascade
  )

  // ----------------------------------------------------
  // Clave primaria
  // ----------------------------------------------------

  @@id([ancestroId, descendienteId])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([ancestroId])

  @@index([descendienteId])

  @@index([ancestroId, profundidad])

  @@index([descendienteId, profundidad])

  @@map("Activos_closure")


}
// ======================================================
// PLANTILLA TÉCNICA
// ======================================================

model PlantillaTecnica {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  descripcion         String?

  version             String?

  observaciones       String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre         String?

  colorHex            String?

  ordenVisual         Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  activos             Activo[]

  atributos           PlantillaTecnicaAtributo[]

  // Las siguientes relaciones se incorporarán
  // cuando existan sus dominios.

  // planes            PlanMantenimiento[]
  // checklists        Checklist[]
  // documentos        Documento[]
  // repuestos         RepuestoRecomendado[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@index([nombre])

  @@map("plantillas_tecnicas")

}

// ======================================================
// TIPO DATO
// ======================================================

model TipoDato {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  descripcion         String?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  atributos           TipoAtributo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([codigo])

  @@map("tipos_dato")

}
// ======================================================
// TIPO ATRIBUTO
// ======================================================

model TipoAtributo {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                  BigInt   @id @default(autoincrement())

  uuid                String   @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  tipoDatoId          BigInt

  unidadMedidaId      BigInt?

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo              String   @unique

  nombre              String

  descripcion         String?

  // ----------------------------------------------------
  // Configuración
  // ----------------------------------------------------


  permiteMultiples    Boolean  @default(false)

  valorMinimo         Decimal?

  valorMaximo         Decimal?

  expresionRegular    String?

  valorPorDefecto     String?

  ordenVisual         Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo              Boolean  @default(true)

  eliminadoEn         DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn            DateTime @default(now())

  actualizadoEn       DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  tipoDato TipoDato
    @relation(
      fields: [tipoDatoId],
      references: [id],
      onDelete: Restrict
    )

  // Se habilitará cuando exista el dominio 04

  // unidadMedida UnidadMedida?
  //   @relation(
  //     fields: [unidadMedidaId],
  //     references: [id],
  //     onDelete: Restrict
  //   )

  plantillas PlantillaTecnicaAtributo[]

  valores ValorAtributoActivo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([nombre])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([tipoDatoId])

  @@index([unidadMedidaId])

  @@index([codigo])

  @@index([nombre])

  @@map("tipos_atributo")

}

// ======================================================
// PLANTILLA TÉCNICA - ATRIBUTO
// ======================================================

model PlantillaTecnicaAtributo {

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  plantillaTecnicaId      BigInt

  tipoAtributoId          BigInt

  // ----------------------------------------------------
  // Configuración
  // ----------------------------------------------------

  obligatorio             Boolean @default(false)

  visible                 Boolean @default(true)

  editable                Boolean @default(true)

  ordenVisual             Int?

  grupo                   String?

  ayuda                   String?

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  plantillaTecnica PlantillaTecnica
    @relation(
      fields: [plantillaTecnicaId],
      references: [id],
      onDelete: Cascade
    )

  tipoAtributo TipoAtributo
    @relation(
      fields: [tipoAtributoId],
      references: [id],
      onDelete: Restrict
    )

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@id([plantillaTecnicaId, tipoAtributoId])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([plantillaTecnicaId])

  @@index([tipoAtributoId])

  @@index([ordenVisual])

  @@map("plantillas_tecnicas_atributos")

}
// ======================================================
// VALOR ATRIBUTO ACTIVO
// ======================================================

model ValorAtributoActivo {

  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id                          BigInt @id @default(autoincrement())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  activoId                    BigInt

  plantillaTecnicaId          BigInt

  tipoAtributoId              BigInt

  // ----------------------------------------------------
  // Valores
  // ----------------------------------------------------

  valorTexto                  String?

  valorEntero                 Int?

  valorDecimal                Decimal? @db.Decimal(18,6)

  valorBoolean                Boolean?

  valorFecha                  DateTime?
  valorFechaHora              DateTime?
  valorHora                   DateTime?

  valorJson                   Json?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn                    DateTime @default(now())

  actualizadoEn               DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  activo Activo
    @relation(
      fields: [activoId],
      references: [id],
      onDelete: Cascade
    )

  plantillaTecnicaAtributo PlantillaTecnicaAtributo
    @relation(
      fields: [plantillaTecnicaId, tipoAtributoId],
      references: [plantillaTecnicaId, tipoAtributoId],
      onDelete: Restrict
    )

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  @@unique([activoId, plantillaTecnicaId, tipoAtributoId])

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@index([activoId])

  @@index([tipoAtributoId])

  @@map("valores_atributo_activo")

}
