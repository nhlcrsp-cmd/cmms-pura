generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ====================================================== 
// DOMINIO 01 - ORGANIZACIÓN 
// Release 2.1 (BORRADOR ARQUITECTÓNICO) 
//======================================================

// ======================================================
// EMPRESA
// ======================================================

model Empresa {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo String @unique

  razonSocial String

  nombreComercial String?

  identificacionFiscal String?

  descripcion String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre String?

  colorHex String?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  unidadesOrganizacionales UnidadOrganizacional[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@unique([razonSocial])
  @@index([codigo])
  @@index([razonSocial])
  @@map("empresas")
}

// ======================================================
// TIPO UNIDAD ORGANIZACIONAL
// ======================================================

model TipoUnidadOrganizacional {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo String @unique

  nombre String

  descripcion String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre String?

  colorHex String?

  ordenVisual Int?

  // ----------------------------------------------------
  // Comportamiento
  // ----------------------------------------------------

  permitePadre Boolean @default(true)

  permiteHijos Boolean @default(true)

  admiteActivos Boolean @default(true)

  admitePersonas Boolean @default(true)

  admiteInventario Boolean @default(true)

  admiteOrdenesTrabajo Boolean @default(true)

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  unidadesOrganizacionales UnidadOrganizacional[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@unique([nombre])
  @@index([codigo])
  @@index([nombre])
  @@map("tipos_unidad_organizacional")
}

// ======================================================
// UNIDAD ORGANIZACIONAL
// ======================================================

model UnidadOrganizacional {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  empresaId BigInt

  tipoUnidadOrganizacionalId BigInt

  padreId BigInt?

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo String

  nombre String

  descripcion String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre String?

  colorHex String?

  ordenVisual Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  tipo TipoUnidadOrganizacional @relation(fields: [tipoUnidadOrganizacionalId], references: [id], onDelete: Restrict)

  padre UnidadOrganizacional? @relation("UnidadPadre", fields: [padreId], references: [id], onDelete: Restrict)

  hijos UnidadOrganizacional[] @relation("UnidadPadre")

  closureComoAncestro UnidadOrganizacionalClosure[] @relation("ClosureAncestro")

  closureComoDescendiente UnidadOrganizacionalClosure[] @relation("ClosureDescendiente")

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------
  activos Activo[]

  @@unique([empresaId, codigo])
  @@unique([empresaId, padreId, nombre])
  @@index([empresaId])
  @@index([tipoUnidadOrganizacionalId])
  @@index([padreId])
  @@index([nombre])
  @@index([empresaId, activo])
  @@map("unidades_organizacionales")
}

// ======================================================
// UNIDAD ORGANIZACIONAL CLOSURE
// ======================================================

model UnidadOrganizacionalClosure {
  // ----------------------------------------------------
  // Clave primaria compuesta
  // ----------------------------------------------------

  ancestroId BigInt

  descendienteId BigInt

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  profundidad Int

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  ancestro UnidadOrganizacional @relation("ClosureAncestro", fields: [ancestroId], references: [id], onDelete: Cascade)

  descendiente UnidadOrganizacional @relation("ClosureDescendiente", fields: [descendienteId], references: [id], onDelete: Cascade)

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@id([ancestroId, descendienteId])
  @@index([ancestroId])
  @@index([descendienteId])
  @@index([ancestroId, profundidad])
  @@index([descendienteId, profundidad])
  @@map("unidades_organizacionales_closure")
}

//////////////////////////////////////////////////////////// 
//02-seguridad.prisma 
// Release 2.1 
// Estado: Revisión consolidada
////////////////////////////////////////////////////////////

model Rol {
  id   BigInt @id @default(autoincrement())
  uuid String @unique @default(uuid())

  codigo      String  @unique
  nombre      String
  descripcion String?

  iconoNombre String?
  colorHex    String?
  ordenVisual Int?

  esSistema Boolean @default(false)
  editable  Boolean @default(true)

  activo        Boolean   @default(true)
  eliminadoEn   DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  usuarios UsuarioRol[]
  permisos RolPermiso[]

  @@unique([nombre])
  @@index([codigo])
  @@index([nombre])
  @@map("roles")
}

model Permiso {
  id            BigInt       @id @default(autoincrement())
  uuid          String       @unique @default(uuid())
  codigo        String       @unique
  recurso       String
  accion        String
  nombre        String
  descripcion   String?
  esSistema     Boolean      @default(true)
  editable      Boolean      @default(false)
  activo        Boolean      @default(true)
  eliminadoEn   DateTime?
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
  roles         RolPermiso[]

  @@unique([recurso, accion])
  @@index([codigo])
  @@index([recurso])
  @@index([accion])
  @@index([nombre])
  @@map("permisos")
}

model Usuario {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Información personal
  // ----------------------------------------------------

  nombre String

  apellido String

  nombreCompleto String?

  email String @unique

  telefono String?

  legajo String?

  // ----------------------------------------------------
  // Autenticación
  // ----------------------------------------------------

  username String @unique

  passwordHash String

  debeCambiarPassword Boolean @default(false)

  ultimoLogin DateTime?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  bloqueado Boolean @default(false)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  roles UsuarioRol[]

  sesiones SesionUsuario[]

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@index([username])
  @@index([email])
  @@index([apellido])
  @@index([nombre])
  @@index([activo])
  @@map("usuarios")
}

model UsuarioRol {
  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  usuarioId BigInt

  rolId BigInt

  // ----------------------------------------------------
  // Configuración
  // ----------------------------------------------------

  asignadoEn DateTime @default(now())

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  rol Rol @relation(fields: [rolId], references: [id], onDelete: Cascade)

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@id([usuarioId, rolId])
  @@index([usuarioId])
  @@index([rolId])
  @@map("usuarios_roles")
}

model RolPermiso {
  rolId BigInt

  permisoId BigInt

  rol Rol @relation(fields: [rolId], references: [id], onDelete: Cascade)

  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("roles_permisos")
}

model SesionUsuario {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  usuarioId BigInt

  // ----------------------------------------------------
  // Seguridad
  // ----------------------------------------------------

  tokenHash String @unique

  refreshTokenHash String?

  // ----------------------------------------------------
  // Información de la sesión
  // ----------------------------------------------------

  ip String?

  userAgent String?

  dispositivo String?

  // ----------------------------------------------------
  // Fechas
  // ----------------------------------------------------

  iniciadaEn DateTime @default(now())

  expiraEn DateTime

  cerradaEn DateTime?

  ultimoAccesoEn DateTime?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activa Boolean @default(true)

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@index([usuarioId])
  @@index([activa])
  @@index([expiraEn])
  @@map("sesiones_usuario")
}

