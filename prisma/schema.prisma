// ======================================================
// MARCA
// ======================================================

model Marca {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo String @unique

  nombre String

  descripcion String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre String?

  colorHex String?

  ordenVisual Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  modelos Modelo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

