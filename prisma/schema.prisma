// ======================================================
// MODELO
// ======================================================

model Modelo {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  marcaId BigInt

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo String

  nombre String

  descripcion String?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre String?

  colorHex String?

  ordenVisual Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  marca Marca @relation(fields: [marcaId], references: [id], onDelete: Restrict)

  // La relación con Activo se agregará en 05-activos.prisma
  // activos Activo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  @@unique([marcaId, codigo])
  @@unique([marcaId, nombre])
  @@index([marcaId])
  @@index([codigo])
  @@index([nombre])
  @@index([ordenVisual])
  @@map("modelos")
}
