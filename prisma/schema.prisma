// ======================================================
// ACTIVO
// ======================================================

model Activo {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  unidadOrganizacionalId BigInt

  tipoActivoId BigInt

  plantillaTecnicaId BigInt?

  modeloId BigInt?

  padreId BigInt?

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  codigo String

  nombre String

  descripcion String?

  numeroSerie String?

  codigoInventario String?

  fechaFabricacion DateTime?

  fechaInstalacion DateTime?

  fechaPuestaMarcha DateTime?

  // ----------------------------------------------------
  // Presentación
  // ----------------------------------------------------

  iconoNombre String?

  colorHex String?

  ordenVisual Int?

  // ----------------------------------------------------
  // Estado
  // ----------------------------------------------------

  activo Boolean @default(true)

  eliminadoEn DateTime?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  unidadOrganizacional UnidadOrganizacional @relation(fields: [unidadOrganizacionalId], references: [id], onDelete: Restrict)

  tipoActivo TipoActivo @relation(fields: [tipoActivoId], references: [id], onDelete: Restrict)

  plantillaTecnica PlantillaTecnica? @relation(fields: [plantillaTecnicaId], references: [id], onDelete: Restrict)

  modelo Modelo? @relation(fields: [modeloId], references: [id], onDelete: Restrict)

  padre Activo? @relation("ActivoPadre", fields: [padreId], references: [id], onDelete: Restrict)

  hijos Activo[] @relation("ActivoPadre")

  closureComoAncestro ActivoClosure[] @relation("ClosureAncestro")

  closureComoDescendiente ActivoClosure[] @relation("ClosureDescendiente")

  atributos ActivoAtributo[]

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@unique([unidadOrganizacionalId, codigo])
  @@index([unidadOrganizacionalId])
  @@index([tipoActivoId])
  @@index([plantillaTecnicaId])
  @@index([modeloId])
  @@index([padreId])
  @@index([nombre])
  @@index([numeroSerie])
  @@index([codigoInventario])
  @@map("activos")
}

// ======================================================
// ACTIVO CLOSURE
// ======================================================

model ActivoClosure {
  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  ancestroId BigInt

  descendienteId BigInt

  // ----------------------------------------------------
  // Información
  // ----------------------------------------------------

  profundidad Int

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  ancestro Activo @relation("ClosureAncestro", fields: [ancestroId], references: [id], onDelete: Cascade)

  descendiente Activo @relation("ClosureDescendiente", fields: [descendienteId], references: [id], onDelete: Cascade)

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@id([ancestroId, descendienteId])
  @@index([ancestroId])
  @@index([descendienteId])
  @@index([ancestroId, profundidad])
  @@index([descendienteId, profundidad])
  @@map("activos_closure")
}

// ======================================================
// ACTIVO ATRIBUTO
// ======================================================

model ActivoAtributo {
  // ----------------------------------------------------
  // Identidad
  // ----------------------------------------------------

  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  // ----------------------------------------------------
  // Relaciones (FK)
  // ----------------------------------------------------

  activoId BigInt

  plantillaAtributoId BigInt

  // ----------------------------------------------------
  // Valor
  // ----------------------------------------------------

  valor String?

  // ----------------------------------------------------
  // Auditoría
  // ----------------------------------------------------

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  // ----------------------------------------------------
  // Relaciones
  // ----------------------------------------------------

  activo Activo @relation(fields: [activoId], references: [id], onDelete: Cascade)

  plantillaAtributo PlantillaAtributo @relation(fields: [plantillaAtributoId], references: [id], onDelete: Restrict)

  // ----------------------------------------------------
  // Restricciones
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Índices
  // ----------------------------------------------------

  // ----------------------------------------------------
  // Base de datos
  // ----------------------------------------------------

  @@unique([activoId, plantillaAtributoId])
  @@index([activoId])
  @@index([plantillaAtributoId])
  @@map("activos_atributo")
}
